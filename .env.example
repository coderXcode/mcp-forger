# =============================================================================
# MCP FORGE — Environment Configuration
# Copy this file to .env and fill in your values.
# The dashboard has a Config page where you can edit these live.
# =============================================================================

# --- App ---
APP_NAME="MCP Forge"
APP_ENV=development            # development | production
SECRET_KEY=change-me-to-a-random-32-char-string
PORT=8000
DEBUG=true
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR

# --- Database ---
# SQLite (default, zero-config for dev)
DB_URL=sqlite:///./data/mcp_forge.db
# PostgreSQL (recommended for production)
# DB_URL=postgresql+asyncpg://user:password@db:5432/mcp_forge

# --- LLM Provider ---
# Which LLM to use for the chat agent. Options: gemini | anthropic | openai
LLM_PROVIDER=gemini

# --- Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- OpenAI (optional fallback) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- GitHub ---
# Personal access token — needed for private repos and higher rate limits
GITHUB_TOKEN=
# Optional: GitHub App credentials for org-level access
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY_PATH=

# --- Security ---
# Encryption key for storing auth profiles in DB (auto-generated if blank)
ENCRYPTION_KEY=

# --- MCP Server (this app exposed as MCP to Claude) ---
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8001
MCP_AUTH_TOKEN=change-me-mcp-secret

# --- Generated Output ---
# Where to write generated MCP projects
OUTPUT_DIR=./generated

# --- Redis (optional — enables real-time pub/sub for multi-worker deploys) ---
# REDIS_URL=redis://redis:6379/0

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# --- Feature Flags ---
ENABLE_LIVE_PROBING=true       # probe live endpoints to discover routes
ENABLE_SECURITY_AUDIT=true     # run security checks on generated code
ENABLE_GIT_SNAPSHOTS=false     # also commit each snapshot to a local git repo
