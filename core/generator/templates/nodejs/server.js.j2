/**
 * {{ project_name }} — MCP Server (Node.js)
 * Auto-generated by MCP Forge. Edit freely.
 * Source: {{ base_url }}
 */
import 'dotenv/config';
import { McpServer, ResourceTemplate } from "@modelcontextprotocol/sdk/server/mcp.js";
import { StdioServerTransport } from "@modelcontextprotocol/sdk/server/stdio.js";
import { z } from "zod";

const BASE_URL = process.env.BASE_URL || "{{ base_url }}";

// ── Auth ───────────────────────────────────────────────────────────────────────
function getHeaders() {
  const headers = { "Content-Type": "application/json" };
  const token = process.env.API_TOKEN || "";
  if (token) headers["Authorization"] = `Bearer ${token}`;
  return headers;
}

// ── MCP Server ─────────────────────────────────────────────────────────────────
const server = new McpServer({ name: "{{ project_name }}", version: "1.0.0" });

{% for tool in tools %}
// {{ tool.summary or tool.operation_id }}
server.tool(
  "{{ tool.operation_id | replace('_', '-') }}",
  "{{ (tool.summary or tool.description or tool.operation_id) | replace('"', '\\"') }}",
  {
    {% for p in tool.path_params %}
    {{ p.name }}: z.string().describe("Path parameter: {{ p.name }}"),
    {% endfor %}
    {% for p in tool.query_params %}
    {{ p.name }}: z.string().optional().describe("{{ p.get('description', p.name) }}"),
    {% endfor %}
    {% if tool.body_schema %}
    payload: z.record(z.unknown()).optional().describe("Request body"),
    {% endif %}
  },
  async (params) => {
    let url = BASE_URL + "{{ tool.path }}";
    {% for p in tool.path_params %}
    url = url.replace("{{"{"}}{{ p.name }}{{"}"}}","params.{{ p.name }}");
    {% endfor %}

    {% if tool.method == "GET" %}
    const qs = new URLSearchParams();
    {% for p in tool.query_params %}
    if (params.{{ p.name }}) qs.append("{{ p.name }}", params.{{ p.name }});
    {% endfor %}
    const resp = await fetch(`${url}?${qs}`, { headers: getHeaders() });
    {% else %}
    const resp = await fetch(url, {
      method: "{{ tool.method }}",
      headers: getHeaders(),
      {% if tool.body_schema %}body: JSON.stringify(params.payload || {}),{% endif %}
    });
    {% endif %}

    if (!resp.ok) throw new Error(`HTTP ${resp.status}: ${await resp.text()}`);
    const text = await resp.text();
    return { content: [{ type: "text", text }] };
  }
);

{% endfor %}

{% for resource in resources %}
// {{ resource.summary or resource.operation_id }}
server.resource(
  "{{ resource.operation_id | replace('_', '-') }}",
  new ResourceTemplate("{{ base_url }}{{ resource.path }}", {
    list: undefined,
  }),
  async (uri, params) => {
    const resp = await fetch(uri.href, { headers: getHeaders() });
    if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
    const text = await resp.text();
    return {
      contents: [{ uri: uri.href, mimeType: "application/json", text }],
    };
  }
);

{% endfor %}

// ── Start ──────────────────────────────────────────────────────────────────────
const transport = new StdioServerTransport();
await server.connect(transport);
console.error("{{ project_name }} MCP server running on stdio");
